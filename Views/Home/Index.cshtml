@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Welcome to BookMVC</h1>
    <p class="lead mt-3">Manage your personal library with ease.</p>

    <div class="card shadow-sm mx-auto mt-5" style="max-width: 400px; border-radius: 15px;">
        <div class="card-body p-4">
            <h5 class="card-title mb-4">Ready to start?</h5>
            <!-- This is your "clicky link" -->
            <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-lg w-100 shadow-sm">
                View My Books
            </a>
            <p class="text-muted mt-3 small">Click above to see your full database collection.</p>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .btn-primary {
        transition: transform 0.2s;
    }
    .btn-primary:hover {
        transform: scale(1.05);
        background-color: #0056b3;
    }
</style>
