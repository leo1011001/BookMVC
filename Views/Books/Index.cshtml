@model IEnumerable<BookMVC.Models.Book>

<h2>Book List</h2>
<a asp-action="Create" class="btn btn-primary">Add New Book</a>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Year</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.YearPublished</td>
            </tr>
        }
    </tbody>
</table>
